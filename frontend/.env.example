# Local dev: Vite proxies /api to backend (see vite.config.ts)
VITE_API_BASE=/api

# Bind dev server on all interfaces so LAN can open http://YOUR_IP:5173
# VITE_DEV_HOST=0.0.0.0

# Vercel: leave VITE_API_BASE unset to auto-show full SOC demo UI
# Or set your live backend:
# VITE_API_BASE=http://10.249.162.244:8787/api

# Force demo UI even when API is configured:
# VITE_DEMO_MODE=true
